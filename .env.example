# Cipher transition effect — animated text scramble on language toggle
# Set to "true" to enable the cipher decryption animation
NEXT_PUBLIC_CIPHER_TRANSITION=true

# Hebrew language toggle — bilingual English/Hebrew with RTL support
# Set to "true" to show the language toggle button
NEXT_PUBLIC_HEBREW_ENABLED=true

# Public contact emails used by the social links component
# Set these to real addresses for production deployments
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_SECURE_CONTACT_EMAIL=security@example.com
