# Cipher transition effect — animated text scramble on language toggle
# Set to "true" to enable the cipher decryption animation
NEXT_PUBLIC_CIPHER_TRANSITION=true

# Multilingual support — English, Hebrew, Russian with language selector
# Set to "true" to show the language dropdown
NEXT_PUBLIC_I18N_ENABLED=true

# Public contact emails used by the social links component
# Leave blank to hide email links in non-production environments
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_SECURE_CONTACT_EMAIL=
