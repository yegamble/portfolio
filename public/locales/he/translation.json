    "ariaLabel": "\u05d0\u05d5\u05d3\u05d5\u05ea\u05d9\u05d9",
    "p1": "\u05d4\u05ea\u05d7\u05dc\u05ea\u05d9 \u05dc\u05db\u05ea\u05d5\u05d1 \u05e7\u05d5\u05d3 \u05d1\u05d0\u05d5\u05e0\u05d9\u05d1\u05e8\u05e1\u05d9\u05d8\u05ea Central Washington \u05d1-2013, \u05e9\u05dd \u05e9\u05d9\u05de\u05e9\u05ea\u05d9 \u05db\u05e0\u05e9\u05d9\u05d0 \u05d0\u05d2\u05d5\u05d3\u05ea \u05d4\u05e1\u05d8\u05d5\u05d3\u05e0\u05d8\u05d9\u05dd \u05d5\u05d6\u05db\u05d9\u05ea\u05d9 \u05d1\u05de\u05dc\u05d2\u05ea \u05d1\u05d5\u05d0\u05d9\u05e0\u05d2. \u05d4\u05d3\u05e8\u05da \u05e9\u05dc\u05d9 \u05dc\u05e7\u05d7\u05d4 \u05d0\u05d5\u05ea\u05d9 \u05de\u05e2\u05d1\u05e8 \u05dc\u05d0\u05d5\u05e7\u05d9\u05d9\u05e0\u05d5\u05e1 \u05d4\u05e9\u05e7\u05d8 \u05dc\u05e0\u05d9\u05d5 \u05d6\u05d9\u05dc\u05e0\u05d3 \u2014 \u05e7\u05d5\u05d3\u05dd \u05dc\u05ea\u05d5\u05d0\u05e8 \u05d1\u05d0\u05d5\u05e0\u05d9\u05d1\u05e8\u05e1\u05d9\u05d8\u05ea \u05d0\u05d5\u05e7\u05dc\u05e0\u05d3, \u05d5\u05d0\u05d7\u05e8 \u05db\u05da \u05dc\u05ea\u05e2\u05e9\u05d9\u05d9\u05ea \u05d4\u05d8\u05db\u05e0\u05d5\u05dc\u05d5\u05d2\u05d9\u05d4 \u05e9\u05dd \u05d1\u05e0\u05d9\u05d9\u05ea \u05ea\u05d5\u05db\u05e0\u05d5\u05ea \u05e9\u05d4\u05d2\u05d9\u05e2\u05d5 \u05dc\u05de\u05d9\u05dc\u05d9\u05d5\u05e0\u05d9 \u05de\u05e9\u05ea\u05de\u05e9\u05d9\u05dd.",
